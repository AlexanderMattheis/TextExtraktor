<!--
    MainWindow.axaml
    UI-Layout der Hauptansicht

    Zweck / User Flow:
    1) Nutzer wählt eine index.html (Quelle)
    2) Nutzer wählt einen Zielpfad für eine Markdown-Datei (Ausgabe)
    3) Nutzer startet die Extraktion
    4) Statusmeldungen werden unten angezeigt

    Architektur / Bindings:
    - MVVM: View bindet an MainWindowViewModel (x:DataType)
    - Bindings: IndexHtmlPfad, MarkdownPfad, Status
    - Commands: BrowseIndexHtmlCommand, BrowseMarkdownCommand, StartBerechnungCommand
    - Lokalisierung: local:Loc Schlüssel (Titel, Labels, Buttontexte)
-->
<Window
    MaxHeight="470"              
    MaxWidth="960"          
    Padding="20"                 
    Title="{local:Loc AppTitle}"
    d:DesignHeight="470"         
    d:DesignWidth="960"
    mc:Ignorable="d"        
    x:Class="TextExtractorGUI.MainWindow"
    x:DataType="mainWindow:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mainWindow="clr-namespace:TextExtractorGUI.ViewModels.MainWindow"
    xmlns:controls="clr-namespace:TextExtractorGUI.Controls"
    xmlns:local="clr-namespace:TextExtractorGUI.Extensions">

    <!--
        Root-Layout: 3 Zeilen
        - Row 0 (Auto): Kopfbereich (Titel + Sprachwahl)
        - Row 1 (*):    Hauptinhalt (ScrollViewer mit Eingabe-/Ausgabeauswahl)
        - Row 2 (Auto): Fußbereich  (Status + Action-Button)
    -->
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14">
        
        <!-- Kopfbereich: links Überschrift, rechts Sprachumschalter -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            
            <!-- Wiederverwendbares Header-Control mit Titel + Untertitel (lokalisiert) -->
            <controls:HeaderView
                Grid.Column="0"
                Title="{local:Loc Header_Title}"
                Subtitle="{local:Loc Header_Subtitle}" />

            <!--
                Sprachwahl:
                - ItemsSource: Liste verfügbarer Sprachen (z. B. "de-DE", "en-US")
            -->
            <ComboBox
                Grid.Column="1"
                VerticalAlignment="Top"
                MinWidth="140"
                SelectedItem="{Binding SelektierteSprache}"
                ItemsSource="{Binding VerfuegbareSprachen}" />
        </Grid>

        <!--
            Hauptinhalt ist scrollbar:
            - Horizontal: aus (Layout soll nicht seitlich „wackeln“)
            - Vertikal: automatisch, falls Fenster kleiner wird
        -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <!--
                Formularbereich: mehrere Karten untereinander
                (RowDefinitions hier sind "Auto" -> Höhe richtet sich nach Inhalt)
            -->
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">

                <!-- Eingabe: Pfad zur index.html (Quelle) -->
                <controls:PathPickerCard
                    Grid.Row="0"
                    Header="{local:Loc Input_Header}"         
                    Path="{Binding IndexHtmlPfad}"           
                    Watermark="{local:Loc Input_Watermark}"
                    ButtonText="{local:Loc Input_Browse}"
                    ButtonCommand="{Binding BrowseIndexHtmlCommand}" />

                <!-- Ausgabe: Pfad zur Markdown-Datei (Ziel) -->
                <controls:PathPickerCard
                    Grid.Row="1"
                    Header="{local:Loc Output_Header}"
                    Path="{Binding MarkdownPfad}"
                    Watermark="{local:Loc Output_Watermark}"
                    ButtonText="{local:Loc Output_SaveAs}"
                    ButtonCommand="{Binding BrowseMarkdownCommand}" />
            </Grid>
        </ScrollViewer>

        <!-- Fußbereich: Status links, Action-Button rechts -->
        <Grid Grid.Row="2" ColumnDefinitions="* Auto" ColumnSpacing="10">

            <!-- Statusanzeige (z. B. "Bereit", Fortschritt, Fehlermeldungen) -->
            <controls:StatusBarView Grid.Column="0"
                                    StatusText="{Binding Status}" />

            <!--
                Rechts: eigener Grid-Container, um Button sauber unten/rechts zu platzieren.
                Row 0 (*) dient als "Spacer", Row 1 (Auto) enthält den Button
            -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                <Button Grid.Row="1"
                        Command="{Binding StartBerechnungCommand}"
                        Content="{local:Loc Action_Extract}"
                        HorizontalAlignment="Right"
                        MinWidth="120"
                        Theme="{DynamicResource AccentButtonTheme}"
                        Margin="15"/>
            </Grid>
        </Grid>
    </Grid>

</Window>